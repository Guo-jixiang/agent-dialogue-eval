{# ── 构建 turn_id → 失败检查点 的映射 ── #}
{% set ns = namespace(turn_annotations={}) %}
{% for ds in dr.dimension_scores %}
  {% for cr in ds.checkpoint_results %}
    {% set is_na = cr.explanation is defined and cr.explanation is not none and cr.explanation.startswith("[未触发]") %}
    {% if not is_na and not cr.passed and cr.evidence and cr.evidence.turn_ids %}
      {% for tid in cr.evidence.turn_ids %}
        {% if tid not in ns.turn_annotations %}
          {% set _ = ns.turn_annotations.update({tid: []}) %}
        {% endif %}
        {% set _ = ns.turn_annotations[tid].append({
            'dim': ds.dimension.value,
            'desc': cr.checkpoint.description,
            'score': cr.score,
            'reason': cr.explanation
          }) %}
      {% endfor %}
    {% endif %}
  {% endfor %}
{% endfor %}

