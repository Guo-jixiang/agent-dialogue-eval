# Evaluator LLM (judge panel) — recommend GPT-4o or equivalent
EVAL_LLM_API_KEY=your_eval_api_key_here
EVAL_LLM_BASE_URL=https://api.openai.com/v1
EVAL_LLM_MODEL=gpt-4o

# Simulator LLM (user simulation) — lower cost model acceptable
SIM_LLM_API_KEY=your_sim_api_key_here
SIM_LLM_BASE_URL=https://api.openai.com/v1
SIM_LLM_MODEL=gpt-4o-mini

# Agent under test (the dialogue model being evaluated)
AGENT_LLM_API_KEY=your_agent_api_key_here
AGENT_LLM_BASE_URL=https://api.openai.com/v1
AGENT_LLM_MODEL=your_model_name_here

# AI Assistant LLM (内置助手，权限与 eval/sim key 隔离)
# 留空则 fallback 到 EVAL_LLM_*；推荐配独立低成本 key（如 gpt-4o-mini）
ASSISTANT_LLM_API_KEY=
ASSISTANT_LLM_BASE_URL=https://api.openai.com/v1
ASSISTANT_LLM_MODEL=gpt-4o-mini

# Simulation concurrency
SIM_CONCURRENCY=8
EVAL_BATCH_SIZE=12

# LLM resilience — rate limiting & retry
LLM_MAX_RETRIES=5
LLM_RATE_LIMIT_RPS=0.0          # 0 = disabled; set to e.g. 5.0 for DeepSeek
LLM_RATE_LIMIT_BURST=10

# Evaluation parameters
MAX_TURNS=30
META_JUDGE_RUNS=3

# Dimension weights (must sum to 1.0)
WEIGHT_FLOW=0.30
WEIGHT_CONSTRAINT=0.25
WEIGHT_KNOWLEDGE=0.20
WEIGHT_STYLE=0.15
WEIGHT_LENGTH=0.10
